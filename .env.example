# 仅供 Docker Compose 或生产部署参考。
# 直接运行 JAR 不需要 .env：默认使用 H2 和本地单节点 State Plane。

# Docker Compose 的 MySQL 密码。
DB_PASSWORD=replace-with-a-strong-database-password

# 多 Server 必须使用同一个 32+ 字节随机会话密钥。
XUANTONG_ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes

# 同一集群保持一致。
XUANTONG_CLUSTER_ID=xuantong-prod

# 每个 Server 节点唯一且稳定。
XUANTONG_GATEWAY_ID=gateway-1
