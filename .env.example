# Xuantong Config 环境变量模板
# 复制此文件为 .env 并填写实际值

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password

# Redis 配置（可选，多机部署时需要）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Broker 鉴权密钥（生产环境必须设置）
BROKER_SECRET_KEY=your_secret_key_here

# 配置值加密密钥（生产环境建议设置 16 位字符串）
CONFIG_ENCRYPT_KEY=
