# 玄同 2.0 环境变量模板
# 复制为 .env 后填写随机高强度值；.env 已被 Git 忽略。

# Docker Compose 数据库配置
DB_PASSWORD=replace-with-a-strong-database-password

# 管理端无状态会话签名密钥。多 Server 必须完全一致，至少 32 字节。
XUANTONG_ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes

# 多 Server 必须使用同一个 Cluster ID，并为每个进程配置唯一且稳定的 Gateway ID。
XUANTONG_CLUSTER_ID=xuantong-local
XUANTONG_GATEWAY_ID=gateway-dev

# State 节点加入已有 Raft 集群时临时设为 true；现有 voter 保持 false。
XUANTONG_STATE_JOIN_EXISTING=false
XUANTONG_STATE_MEMBERSHIP_CATCH_UP_TIMEOUT_MS=120000
XUANTONG_STATE_MEMBERSHIP_MAXIMUM_CATCH_UP_GAP=0
# 容器/NAT 场景可覆盖本地监听地址；留空/0 时沿用 peers 中当前节点的公布地址。
XUANTONG_STATE_RPC_BIND_HOST=
XUANTONG_STATE_RPC_BIND_PORT=0
# Apache Ratis 默认会无限保留 Snapshot；玄同默认保留最近 3 份。
XUANTONG_CONFIG_STATE_SNAPSHOT_RETENTION_FILES=3
# 管理端为滚动离线备份强制创建单个 Group Snapshot 的超时。
XUANTONG_STATE_SNAPSHOT_MANAGEMENT_TIMEOUT_MS=120000
XUANTONG_STATE_STORAGE_FREE_MIN_BYTES=536870912

# operationId 原结果与 Watch ChangeLog 的有界保留窗口；生产值需经容量测试确认。
XUANTONG_CONFIG_OPERATION_REPLAY_WINDOW=75000
XUANTONG_REGISTRY_OPERATION_REPLAY_WINDOW=150000

# Server 原生 Socket.D TCP TLS/mTLS。生产证书必须包含客户端实际使用的 DNS/IP SAN。
XUANTONG_CONTROL_TLS_ENABLED=false
XUANTONG_CONTROL_TLS_KEY_STORE=
XUANTONG_CONTROL_TLS_KEY_STORE_TYPE=PKCS12
XUANTONG_CONTROL_TLS_KEY_STORE_PASSWORD=
XUANTONG_CONTROL_TLS_TRUST_STORE=
XUANTONG_CONTROL_TLS_TRUST_STORE_TYPE=PKCS12
XUANTONG_CONTROL_TLS_TRUST_STORE_PASSWORD=
# NONE / WANT / REQUIRE
XUANTONG_CONTROL_TLS_CLIENT_AUTH=NONE

# Client/Starter/Plugin 示例使用的 TLS/mTLS 环境变量。
XUANTONG_CLIENT_TLS_ENABLED=false
XUANTONG_CLIENT_TLS_TRUST_STORE=
XUANTONG_CLIENT_TLS_TRUST_STORE_TYPE=PKCS12
XUANTONG_CLIENT_TLS_TRUST_STORE_PASSWORD=
XUANTONG_CLIENT_TLS_KEY_STORE=
XUANTONG_CLIENT_TLS_KEY_STORE_TYPE=PKCS12
XUANTONG_CLIENT_TLS_KEY_STORE_PASSWORD=
XUANTONG_CLIENT_TLS_KEY_PASSWORD=
XUANTONG_CLIENT_TLS_RELOAD_INTERVAL_MS=30000

# 独立外部 Socket.D Hello + Probe。多个地址只会在一个总 deadline 内顺序尝试两个。
XUANTONG_PROBE_SERVERS=127.0.0.1:8090
# config / discovery；生产建议分别部署两个 Probe 实例。
XUANTONG_PROBE_PROFILE=config
XUANTONG_PROBE_NAMESPACE=public
XUANTONG_PROBE_GROUP=DEFAULT_GROUP
XUANTONG_PROBE_TOKEN=
XUANTONG_PROBE_PORT=9118
XUANTONG_PROBE_INTERVAL_MS=15000
