{
  "properties": [
    {
      "name": "xuantong.config.serverAddresses",
      "type": "java.util.List",
      "description": "玄同 2.0 原生 Socket.D TCP 控制面地址，例如 127.0.0.1:8090"
    },
    {
      "name": "xuantong.config.namespace",
      "type": "java.lang.String",
      "defaultValue": "public",
      "description": "配置所属 Namespace"
    },
    {
      "name": "xuantong.config.group",
      "type": "java.lang.String",
      "defaultValue": "DEFAULT_GROUP",
      "description": "配置所属 Group"
    },
    {
      "name": "xuantong.config.accessToken",
      "type": "java.lang.String",
      "defaultValue": "",
      "description": "客户端访问令牌"
    },
    {
      "name": "xuantong.config.applicationName",
      "type": "java.lang.String",
      "defaultValue": "solon-application",
      "description": "管理端连接视图中的应用名称"
    },
    {
      "name": "xuantong.config.clientInstanceId",
      "type": "java.lang.String",
      "description": "可选的客户端运行实例标识；默认由客户端按运行环境自动生成"
    },
    {
      "name": "xuantong.config.stateGroupId",
      "type": "java.lang.String",
      "defaultValue": "config-default",
      "description": "Config State 权威组标识"
    },
    {
      "name": "xuantong.config.clusterId",
      "type": "java.lang.String",
      "defaultValue": "",
      "description": "控制面集群标识；留空时由首次成功 Hello 自动锁定"
    },
    {
      "name": "xuantong.config.transportGeneration",
      "type": "java.lang.Long",
      "defaultValue": 0,
      "description": "控制面传输代次；0 表示自动锁定"
    },
    {
      "name": "xuantong.config.transportPool",
      "type": "java.lang.String",
      "defaultValue": "tcp-default",
      "description": "基础设施兼容池"
    },
    {
      "name": "xuantong.config.tenant",
      "type": "java.lang.String",
      "defaultValue": "default",
      "description": "控制面租户标识"
    }
  ]
}
